rules:
  - RULE-SET,OpenAi,全球加速
  - RULE-SET,Emby,Emby服务
  - RULE-SET,Youtube,国际媒体
  - RULE-SET,GlobalMedia,国际媒体
  - RULE-SET,Github,全球加速
  - RULE-SET,Microsoft,全球加速
  - RULE-SET,Google,全球加速
  - RULE-SET,Telegram,全球加速
  - RULE-SET,Twitter,全球加速
  - RULE-SET,ProxyLite,全球加速
  - RULE-SET,BankUS,金融服务
  - RULE-SET,ChinaIP,DIRECT
  - RULE-SET,Direct,DIRECT
  - RULE-SET,Lan,DIRECT
  - RULE-SET,Streaming,国际媒体
  - RULE-SET,StreamingCN,DIRECT
  - GEOIP,CN,DIRECT
  - MATCH,全球加速
