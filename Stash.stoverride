name: MihomoParty Override
desc: Convert from MihomoParty.yaml for Stash

proxy-groups:
  - name: 全球加速
    type: select
    proxies:
      - 自动选择
      - 日本节点
      - 美国节点
      - 德国节点
    icon: https://raw.githubusercontent.com/Orz-3/mini/master/Color/Global.png

  - name: 国际媒体
    type: select
    proxies:
      - 自动选择
      - 日本节点
      - 美国节点
      - 德国节点
    icon: https://raw.githubusercontent.com/Orz-3/mini/master/Color/Streaming.png

  - name: Emby服务
    type: select
    proxies:
      - 自动选择
      - 日本节点
      - 美国节点
      - 德国节点
    icon: https://raw.githubusercontent.com/Orz-3/mini/master/Color/Emby.png

  - name: 金融服务
    type: select
    proxies:
      - 自动选择
      - 日本节点
      - 美国节点
      - 德国节点
    icon: https://raw.githubusercontent.com/Orz-3/mini/master/Alpha/Bitcloud.png

  - name: 自动选择
    type: url-test
    include-all: true
    interval: 28800
    tolerance: 100
    icon: https://raw.githubusercontent.com/Orz-3/mini/master/Color/Urltest.png

  - name: 日本节点
    type: url-test
    include-all: true
    interval: 28800
    tolerance: 100
    filter: "日|东京|JP|(?i)Japan"
    icon: https://raw.githubusercontent.com/Orz-3/mini/master/Color/JP.png

  - name: 美国节点
    type: url-test
    include-all: true
    interval: 28800
    tolerance: 100
    filter: "美|US|(?i)States|American"
    icon: https://raw.githubusercontent.com/Orz-3/mini/master/Color/US.png

  - name: 德国节点
    type: url-test
    include-all: true
    interval: 28800
    tolerance: 100
    filter: "德|🇩🇪|DE|(?i)Germany"
    icon: https://raw.githubusercontent.com/Orz-3/mini/master/Color/DE.png


rule-providers:
  AdBlock:
    type: http
    behavior: domain
    format: text
    interval: 86400
    url: https://raw.githubusercontent.com/Cats-Team/AdRules/main/adrules_domainset.txt
    path: ./ruleset/anti-ad-clash.txt

  Youtube:
    type: http
    behavior: classical
    format: text
    interval: 86400
    url: https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/YouTube/YouTube.yaml
    path: ./ruleset/Youtube.yaml

  OpenAi:
    type: http
    behavior: classical
    format: yaml
    interval: 86400
    url: https://gist.githubusercontent.com/ddgksf2013/cb4121e8b5c5d865cc949cb8120320c4/raw/Ai.yaml
    path: ./ruleset/OpenAi.yaml

  Emby:
    type: http
    behavior: classical
    format: yaml
    interval: 86400
    url: https://raw.githubusercontent.com/ddgksf2013/Filter/master/Emby.yaml
